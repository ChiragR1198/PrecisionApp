{
  "expo": {
    "name": "PEG Summits",
    "slug": "PrecisionGlobalSummits",
    "version": "1.1.6",
    "owner": "raviridge2021",
    "orientation": "portrait",
    "icon": "./src/assets/images/app-icon.png",
    "scheme": "precisionglobalsummits",
    "userInterfaceStyle": "automatic", 
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/images/color_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "imageWidth": 400
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.precisionglobe.app",
      "buildNumber": "21",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to take photos.",
        "NSMicrophoneUsageDescription": "This app needs access to your microphone for video recording.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select images.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 18,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./src/assets/images/app-icon.png"
      },
      "icon": "./src/assets/images/app-icon.png",
      "splash": {
        "image": "./src/assets/images/color_logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "imageWidth": 400,
        "dark": {
          "backgroundColor": "#000000"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.precisionglobe.app"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/color_logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "imageWidth": 400,
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-navigation-bar",
        {
          "barStyle": "light-content",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone"
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/color_logo.png",
          "color": "#2563EB",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "./plugins/withAndroidPhoneOnly"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "barStyle": "light-content",
        "backgroundColor": "#000000"
      },
      "eas": {
        "projectId": "7383a335-b805-4b75-acb9-c67ce0ef4376",
        "owner": "raviridge2021"
      }
    }
  }
}